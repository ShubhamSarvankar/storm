# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info          # trace | debug | info | warn | error

# ── Service Ports ─────────────────────────────────────────────
PORT=3000               # api: 3000, gateway: 3001 (set per-service in compose)

# ── MongoDB ───────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme          # change before use
MONGO_URI=mongodb://admin:changeme@mongo:27017/storm?authSource=admin
# Note: the database name is embedded in MONGO_URI above ("storm")

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme               # change before use
REDIS_URL=redis://:changeme@redis:6379

# ── JWT ───────────────────────────────────────────────────────
# Must be a 64-byte hex string (128 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
# Note: access token TTL = 15 min, refresh token TTL = 7 days (hardcoded in auth.service.ts)

# ── Encryption ────────────────────────────────────────────────
# AES-256-GCM key — must be exactly 32 bytes (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=replace_with_32_byte_hex_key

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PUBLIC_MAX=100             # requests per hour, unauthenticated
RATE_LIMIT_AUTHED_MAX=1000            # requests per hour, authenticated
RATE_LIMIT_WS_MSG_MAX=60             # messages per minute, per WS connection