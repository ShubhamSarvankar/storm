    "express-rate-limit": "^7.0.0",
    "helmet": "^8.0.0",
    "pino-http": "^10.0.0",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "mongoose": "^8.0.0",
    "supertest": "^7.0.0",
    "vitest": "^2.0.0"
