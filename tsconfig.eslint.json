{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@storm/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*.ts",
    "packages/api/src/**/*.ts",
    "packages/gateway/src/**/*.ts",
    "packages/worker/src/**/*.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**"
  ]
}